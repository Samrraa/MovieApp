<?xml version="1.0" encoding="utf-8"?>
<rotate xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromDegrees="0"
    android:pivotX="50%"
    android:pivotY="50%"
    android:toDegrees="360">

    <layer-list>
        <item>
            <shape
                android:innerRadiusRatio="3"
                android:shape="ring"
                android:thicknessRatio="15"
                android:useLevel="false">

                <gradient
                    android:angle="0"
                    android:endColor="@color/brand_primary"
                    android:startColor="@color/brand_tertiary"
                    android:type="sweep"/>

            </shape>
        </item>

        <item android:left="40dp" android:right="5dp">
            <shape android:shape="oval">
                <solid android:color="@color/brand_primary" />
                <size android:width="4dp" android:height="4dp" />
            </shape>
        </item>
    </layer-list>

</rotate>