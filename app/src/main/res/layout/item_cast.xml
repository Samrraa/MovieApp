<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="com.karrar.movieapp.ui.models.CastUiState" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.ActorsInteractionListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="200dp"
        android:layout_height="64dp"
        android:layout_marginHorizontal="6dp"
        android:layout_marginVertical="6dp"
        android:background="@drawable/cast_card_shape"
        android:onClick="@{() -> listener.onClickActor(item.id)}">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/cast_image"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@color/gray"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toStartOf="@+id/cast_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:posterImage="@{item.imageUrl}"
            app:shapeAppearanceOverlay="@style/CastImgCorners"
            tools:srcCompat="@drawable/image" />

        <TextView
            android:id="@+id/cast_name"
            style="@style/Regular.Medium.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:lines="1"
            android:text="@{item.name}"
            android:textAlignment="textStart"
            app:layout_constraintBottom_toTopOf="@+id/cast_character_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cast_image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Cristian Bale" />

        <!--        character name not implemented yet-->
        <TextView
            android:id="@+id/cast_character_name"
            style="@style/Regular.Small.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lines="1"
            android:text="@{item.character}"
            android:textAlignment="textStart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/cast_name"
            app:layout_constraintTop_toBottomOf="@+id/cast_name"
            tools:text="Bruce Wayne" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
