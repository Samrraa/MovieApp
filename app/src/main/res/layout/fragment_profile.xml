<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.profile.ProfileViewModel" />

        <variable
            name="shortcutAdapter"
            type="com.karrar.movieapp.ui.profile.adapter.ShortcutsAdapter" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_screen">

        <View
            android:id="@+id/user_data_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/cta_card_background"
            android:onClick="@{()-> viewModel.onClickLogin()}"
            app:layout_constraintBottom_toBottomOf="@id/iv_image"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_image"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@color/shade_quinairy"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@id/user_data_card"
            app:layout_constraintEnd_toStartOf="@id/tv_title"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@id/user_data_card"
            app:layout_constraintTop_toTopOf="@id/user_data_card"
            app:profileImage="@{viewModel.profileDetailsUIState.avatarPath}"
            app:shapeAppearanceOverlay="@style/Circle" />

        <TextView
            android:id="@+id/tv_title"
            style="@style/Title.SM"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{viewModel.profileDetailsUIState.isLoggedIn? viewModel.profileDetailsUIState.name : @string/login_or_sign_up}"
            android:textColor="@color/shade_primary"
            android:textSize="16sp"
            app:layout_constraintBottom_toTopOf="@id/tv_caption"
            app:layout_constraintEnd_toStartOf="@id/iv_arrow"
            app:layout_constraintStart_toEndOf="@id/iv_image"
            app:layout_constraintTop_toTopOf="@id/iv_image"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tv_caption"
            style="@style/Body_SM.Medium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{viewModel.profileDetailsUIState.isLoggedIn? viewModel.profileDetailsUIState.username : @string/to_personalize_your_experience}"
            android:textColor="@color/shade_secondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_image"
            app:layout_constraintEnd_toEndOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="@id/tv_title"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/outline_alt_arrow_right"
            app:layout_constraintBottom_toBottomOf="@id/iv_image"
            app:layout_constraintEnd_toEndOf="@id/user_data_card"
            app:layout_constraintTop_toTopOf="@id/iv_image"
            app:tint="@color/shade_tertiary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:adapter="@{shortcutAdapter}"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/user_data_card"
            tools:listitem="@layout/item_shortcut" />

        <TextView
            android:id="@+id/tv_settings"
            style="@style/Title.SM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="@string/settings"
            android:textColor="@color/shade_primary"
            android:textSize="16sp"
            app:layout_constraintBottom_toTopOf="@id/options"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_chips" />

        <LinearLayout
            android:id="@+id/options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/cta_card_background"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_settings">

            <include
                android:id="@+id/theme_mode"
                layout="@layout/item_settings_option"
                app:hasDivider="@{true}"
                app:hasSwitch="@{true}"
                app:iconDrawable="@{@drawable/due_tone_moon}"
                app:isVisible="@{true}"
                app:title="@{@string/dark_mode}" />

            <include
                android:id="@+id/language"
                layout="@layout/item_settings_option"
                app:hasDivider="@{true}"
                app:iconDrawable="@{@drawable/due_tone_language}"
                app:isVisible="@{true}"
                app:title="@{@string/language}" />

            <include
                android:id="@+id/content"
                layout="@layout/item_settings_option"
                app:hasDivider="@{viewModel.profileDetailsUIState.isLoggedIn}"
                app:iconDrawable="@{@drawable/due_tone_color_switch}"
                app:isVisible="@{true}"
                app:title="@{@string/content_preferences}" />

            <include
                android:id="@+id/logout"
                layout="@layout/item_settings_option"
                app:hasDivider="@{false}"
                app:iconDrawable="@{@drawable/due_tone_logout}"
                app:isVisible="@{viewModel.profileDetailsUIState.isLoggedIn}"
                app:title="@{@string/logout}" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_version"
            style="@style/Body_SM.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="Version 1.0.1"
            android:textColor="@color/shade_tertiary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/options"
            app:layout_constraintVertical_bias="0" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>