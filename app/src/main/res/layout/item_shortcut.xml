<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="item"
            type="com.karrar.movieapp.ui.profile.adapter.Shortcut" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.profile.adapter.ShortcutsInteractionListener" />
    </data>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/chip_background"
        android:gravity="center"
        android:onClick="@{()->listener.onShortcutClick(item)}"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="6dp"
            app:iconRes="@{item.iconRes}"
            app:tint="@color/brand_primary" />

        <TextView
            android:id="@+id/tv_label"
            style="@style/Label_MD.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/shade_primary"
            android:textSize="12sp"
            app:textRes="@{item.titleRes}" />

    </LinearLayout>
</layout>